{
  "permissions": {
    "allow": [
      "Bash(python main.py)",
      "Bash(curl -s --retry 10 --retry-delay 1 --retry-connrefused -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:8000/docs)",
      "Bash(curl -s --retry 20 --retry-delay 1 --retry-connrefused -o /dev/null -w \"HTTP %{http_code}\\\\n\" http://localhost:3000)",
